{
  "name": "restify-printer",
  "version": "1.0.0",
  "description": "Restify Desktop Printer Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "printer",
    "thermal",
    "pos",
    "restaurant"
  ],
  "author": "Restify",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "node-thermal-printer": "^4.4.4",
    "pusher-js": "^8.4.0-rc2",
    "auto-launch": "^5.0.6",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.restify.printer",
    "productName": "Restify Printer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/Restify.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/Restify.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/Restify.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "your-github-username",
      "repo": "restify-printer",
      "private": false
    }
  }
}
